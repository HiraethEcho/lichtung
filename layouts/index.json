{{- $index := slice -}}
{{- range site.RegularPages -}}
  {{- $page := . -}}
  {{- $content := "" -}}
  {{- $searchContent := default true (default site.Params.SearchContent .Params.SearchContent) -}}
  {{- if and $searchContent (not (in (slice "archive" "about") .Layout)) -}}
    {{- $content = .Plain | replaceRE "#{1,6}\\s*" "" -}}
    {{- $content = $content | replaceRE "\\*\\*|__" "" -}}
    {{- $content = $content | replaceRE "\\*|_" "" -}}
    {{- $content = $content | replaceRE "!\\[([^\\]]*)\\]\\([^\\)]+\\)" "" -}}
    {{- $content = $content | replaceRE "\\[([^\\]]+)\\]\\([^\\)]+\\)" "$1" -}}
    {{- $content = $content | replaceRE "\\n{3,}" "\\n\\n" -}}
    {{- $content = $content | replaceRE "\\s+" " " -}}
  {{- end -}}
  {{- $taxdata := dict -}}
  {{- range $taxonomyName, $_ := site.Taxonomies -}}
    {{- $termdata := slice -}}
    {{- range ($page.GetTerms $taxonomyName) -}}
      {{- $termdata = $termdata | append .LinkTitle -}}
    {{- end -}}
    {{- $taxdata = merge $taxdata (dict $taxonomyName $termdata) -}}
  {{- end -}}
  {{- $index = $index | append (dict
    "title"      .Title
    "file"       .File.BaseFileName
    "summary"    .Params.summary
    "content"    $content
    "permalink"  .RelPermalink
    "taxonomies" $taxdata)
  -}}
{{- end -}}
{{- $index | jsonify -}}
